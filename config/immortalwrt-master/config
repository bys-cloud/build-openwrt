# ==============================
# 小米 AX6S (RB03/RX3000) 专用
# 硬件：256M内存 + 128M闪存
# ==============================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_xiaomi_rx3000=y

# 🔴 安全大存储（96MB，128M闪存极限安全值）
CONFIG_TARGET_ROOTFS_PARTSIZE=96

# iStoreOS 标配
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-store=y

# 你要的双代理插件
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-app-openclash=y

# 中文语言+基础依赖
CONFIG_LUCI_LANG_zh_cn=y
CONFIG_DEFAULT_LUCI_LANG=zh_cn
CONFIG_PACKAGE_luci-i18n-argon-mod-zh-cn=y
CONFIG_PACKAGE_luci-i18n-store-zh-cn=y
CONFIG_PACKAGE_luci-i18n-passwall2-zh-cn=y
CONFIG_PACKAGE_luci-i18n-openclash-zh-cn=y

# 无线驱动正常（官方原生驱动）
CONFIG_PACKAGE_kmod-mt7915e=y
CONFIG_PACKAGE_mt7915-firmware=y
